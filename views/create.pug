doctype html
html
  head
    title Create User
  body
    h1 Создать пользователя

    if error
      p(style="color: red;") #{error}

    form(action="/users" method="POST")
      div
        label Имя:
        input(type="text" name="name" required)

      div
        label Email:
        input(type="email" name="email" required)

      button(type="submit") Создать

    a(href="/users") Назад